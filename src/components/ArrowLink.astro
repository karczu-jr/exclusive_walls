---
interface Props {
    linkHref?: string; 
    text?: string;
    class?: string;
}

const { linkHref, text, class: className, ...rest } = Astro.props;
---

{linkHref && text && (
    <a href={linkHref} class:list={["arrow-link", className]} {...rest}>
        {text}
        <i class="material-symbols-outlined arrow-link__icon">chevron_right</i>
    </a>
)}

<style lang="scss">
@use "../styles/variables" as *;
@use "../styles/mixins" as *;

    .arrow-link {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        color: inherit;
        text-decoration: none;
        font-weight: 600;
        
        // Wyłączamy ewentualne globalne podkreślenie linków
        &::after {
            content: none;
        }

        &__icon {
            font-size: 1.25rem; // Taki sam rozmiar jak w OfferItem
            transition: transform 0.3s ease-out;
        }

        // --- EFEKTY HOVER ---
        // Zostawiamy czyste i eleganckie odsunięcie chevrona
        &:hover {
            .arrow-link__icon {
                transform: translateX(6px); // Gładkie odsunięcie w prawo
            }
        }
    }
</style>