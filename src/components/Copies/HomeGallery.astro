---
import img1 from '../assets/img/about_photo_1.jpg';
import img2 from '../assets/img/about_photo_2.jpg';
import img3 from '../assets/img/about_photo_3.jpg';
import { Image } from 'astro:assets';

import SectionIntro from './SectionIntro.astro';
---

<section class="gallery">
    
    <div class="wrapper">
        
        <div class="gallery__container grid">
            
            <div class="gallery__images col-8 col-desktop-12">
                <Image src={img1} alt="Opis 1" />
                <Image src={img2} alt="Opis 2" />
                <Image src={img3} alt="Opis 3" />
            </div>

            <div class="gallery-text__content col-4">
                <span class="caption">O firmie</span>
                <h2>Dlaczego Exclusive Walls to nowa definicja dekoracji ścian?</h2>
                <p>
                    Stawiamy na bezkompromisową jakość druku UV na każdym podłożu – od surowego betonu po gładkie szkło. Nasza technologia to gwarancja ekologicznych tuszy i trwałości, której nie dają tradycyjne metody. Zyskujesz idealnie gładki obraz bez widocznych łączeń, w pełni zintegrowany z architekturą Twojego wnętrza.
                </p>
            </div>

        </div>
        
    </div>
</section>

<style lang="scss">
@use "../styles/variables" as *;
@use "../styles/mixins" as *;

    // Główny blok BEM
    .gallery {
        margin-top: 9rem; 
        background-color: var(--bg-color-2); 
        padding-top: 4rem;
        padding-bottom: 4rem;

        // Kompiluje się do .gallery__container
        &__container {
            align-items: flex-start;
        }

        // Kompiluje się do .gallery__images
        &__images {
            display: grid;
            grid-template-columns: 1fr 1fr; 
            gap: 1.5rem; 

            img {
                width: 100%;
                height: 100%;
                object-fit: cover; 
            }
            
            img:nth-child(1),
            img:nth-child(2) {
                aspect-ratio: 1 / 1; 
            }

            img:nth-child(3) {
                grid-column: 1 / -1; 
                aspect-ratio: 2 / 1; 
            }
        }

        @include respond-to("desktop") {
            
            // Kompiluje się do .gallery__intro
            :global(.gallery__intro) {
                order: 1; 
                margin-bottom: 2rem; 
            }

            &__images {
                order: 2; 
            }
        }
    }
</style>