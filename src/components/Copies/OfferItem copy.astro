---
// Odbieramy dane, które przekażemy z głównego pliku
const { title, description, imageSrc, linkHref } = Astro.props;
---

<article class="offer-card">
    <img src={imageSrc} alt={title} class="offer-card__image" />
    
    <h3 class="offer-card__title">{title}</h3>
    <p class="offer-card__text">{description}</p>
    
    <a href={linkHref} class="offer-card__link">Dowiedz się więcej</a>
</article>

<style lang="scss">
    /* Lokalne style tylko dla tej jednej karty */
    .offer-card {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        
        &__image {
            width: 100%;
            aspect-ratio: 4 / 3; // Opcjonalnie: stałe proporcje zdjęcia
            object-fit: cover;
        }

        &__title {
            font-size: 1.5rem;
            margin: 0;
        }

        &__text {
            color: var(--text-muted);
            margin: 0;
            flex-grow: 1; // Wypycha link na sam dół karty, jeśli teksty mają różną długość!
        }

        &__link {
            width: fit-content;
            text-decoration: none;
            // Tutaj możesz dodać swój fajny efekt podkreślenia z :after :)
        }
    }
</style>