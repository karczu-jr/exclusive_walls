---
const { title, description, imageSrc, linkHref, linkText, class: className } = Astro.props;
---

<article class:list={["offer-item", className]}>
    <a href={linkHref} class="offer-item__link-wrapper">
        
        <div class="offer-item__image-wrapper">
            <img src={imageSrc} alt={title} />
        </div>
        
        <div class="offer-item__content">
            {title && (
                <h3 class="offer-item__title">{title}</h3>
            )}
            {description && (
                <p class="offer-item__text">{description}</p>
            )}
            
            <div class="offer-item__fake-link">
                <span class="fake-link-text">{linkText}</span>
                <span class="material-symbols-outlined fake-link-icon">chevron_right</span>
            </div>
        </div>

    </a>
</article>

<style lang="scss">
.offer-item {
    // Karta jest kontenerem na 100% wysokości grida
    height: 100%;

    &__link-wrapper {
        display: flex;
        flex-direction: column;
        height: 100%;
        text-decoration: none; // Usuwamy domyślne podkreślenie linku
        color: inherit;        // Dziedziczymy kolor tekstu

        // ==========================================
        // HOVER NA CAŁEJ KARCIE (MAGIA DZIEJE SIĘ TU)
        // ==========================================
        &:hover {
            // 1. Zoom zdjęcia
            .offer-item__image-wrapper img {
                transform: scale(1.1); 
            }
            
            // 2. Podkreślenie tekstu w "fake linku"
            .fake-link-text::after {
                left: 0;
                right: auto;
                width: 100%;
            }

            // 3. Odsunięcie chevrona
            .fake-link-icon {
                transform: translateX(6px);
            }
        }
    }

    &__image-wrapper {
        width: 100%;
        aspect-ratio: 4 / 3;
        overflow: hidden; // Przycina powiększone zdjęcie do rogów wrappera
        // margin-bottom: 1.5rem; // Odstęp od tekstu
        margin-bottom: 1rem; // Odstęp od tekstu
        
        img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s ease-out; // Gładkie przejście
        }
    }

    &__content {
        display: flex;
        flex-direction: column;
        flex-grow: 1; // Rozciąga się, by wypchnąć link na dół
    }

    &__title {
        font-size: 1.5rem;
        margin-bottom: 4px;
    }

    &__text {
        color: #555;
        margin: 0 0 1rem 0;
        flex-grow: 1; // Wypycha fake-link na sam dół karty
    }

    // STYLOWANIE NASZEGO WIZUALNEGO LINKU
    &__fake-link {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-weight: 500;
        margin-top: auto; // Gwarantuje, że przyklei się do dołu

        // .fake-link-text {
        //     position: relative;
            
        //     // Pasek podkreślenia
        //     &::after {
        //         content: '';
        //         position: absolute;
        //         height: 1px;
        //         background-color: currentColor;
        //         bottom: -2px;
        //         width: 0;
        //         right: 0;
        //         transition: width 0.3s ease-out;
        //     }
        // }

        .fake-link-icon {
            font-size: 1.25rem;
            transition: transform 0.3s ease-out;
        }
    }
}
</style>