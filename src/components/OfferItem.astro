---
interface Props {
        title?: string;
        description?: string;
        imageSrc: string;
        linkHref: string;
        linkText?: string;
        class?: string;
    }

    const { title, description, imageSrc, linkHref, linkText, class: className } = Astro.props;
---

<article class:list={["offer-item", className]}>
    <a href={linkHref} class="offer-item__link-wrapper">
        
        <div class="offer-item__background">
            <img src={imageSrc} alt={title || "Oferta"} />
            <div class="offer-item__overlay"></div>
        </div>
        
        <div class="offer-item__content">
            {title && (
                <h3 class="offer-item__title">{title}</h3>
            )}

            {linkText && (
                <div class="offer-item__fake-link">
                    <span class="fake-link-text">{linkText}</span>
                    <span class="material-symbols-outlined fake-link-icon">chevron_right</span>
                </div>
            )}
            
            {description && (
                <p class="offer-item__text small-p">{description}</p>
            )}
        </div>

    </a>
</article>

<style lang="scss">
@use "../styles/variables" as *;
@use "../styles/mixins" as *;
.offer-item {
    height: 100%;
    // Tutaj nadajemy kształt całej karcie. Usunąłem aspect-ratio z samego obrazka i przeniosłem wyżej
    aspect-ratio: 4 / 3;
    overflow: hidden;   // Upewnia się, że obrazek nie wystaje poza kartę
    position: relative; // Konieczne do pozycjonowania warstw wewnątrz

    &__link-wrapper {
        display: block;
        height: 100%;
        width: 100%;
        text-decoration: none;
        color: #ffffff; // Tekst musi być jasny, by kontrastował z gradientem!

        // ==========================================
        // HOVER NA CAŁEJ KARCIE
        // ==========================================
        &:hover {
            .offer-item__background img {
                transform: scale(1.08); // Delikatny zoom (1.1 bywa czasem zbyt agresywne, 1.08 jest płynniejsze)
            }
            
            .fake-link-icon {
                transform: translateX(6px);
            }
        }
    }

    // --- WARSTWA TŁA ---
    &__background {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;

        img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease-out; 
        }
    }

    // --- WARSTWA GRADIENTU ---
    &__overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 2;
        // Gradient: Z góry (przezroczysty) do dołu (ciemny czarny/szary na 80%)
        background: linear-gradient(
            to top, 
            rgba(0, 0, 0, 0.85) 0%, 
            rgba(0, 0, 0, 0.4) 40%, 
            transparent 100%
        );
    }

    // --- WARSTWA TREŚCI ---
    &__content {
        position: relative; // Dźwiga treść nad absolute
        z-index: 3;
        display: flex;
        flex-direction: column;
        justify-content: flex-end; // MAGIA: Wypycha wszystko do dołu!
        height: 100%;
        
        // Stała odległość od krawędzi (możesz użyć zmiennej np. 2rem)
        padding: 2rem;

        @include respond-to("tablet") {
            padding: 1rem;
        }
        
    }

    &__title {
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
        color: #ffffff; // Wymuszamy biel na nagłówku
    }

    &__fake-link {
        display: inline-flex;
        align-items: center;
        margin-bottom: 0.5rem;
        gap: 4px;
        font-weight: 600;
        color: var(--text-color);

        .fake-link-icon {
            font-size: 1.25rem;
            transition: transform 0.3s ease-out;
        }
    }

    &__text {
        color: rgba(255, 255, 255, 0.85); // Lekko przygaszony biały dla opisu
        display: -webkit-box;
        -webkit-line-clamp: 3; // Opcjonalny trick: ucina tekst po 2 linijkach dodając "..."
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
}
</style>